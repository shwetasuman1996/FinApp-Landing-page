# Copy to .env.production and set values, OR configure these as
# build-time env vars on whichever platform hosts the static site
# (Netlify, Vercel, Render Static, etc).
#
# After the backend is deployed to Render, set VITE_API_URL to its URL
# (no trailing slash) so /api/contact submissions succeed in prod.

VITE_API_URL=https://finapp-api.onrender.com

# URL of the main FinApp learning app (used by login/CTA links).
VITE_APP_URL=https://finapp-1lpk.onrender.com
