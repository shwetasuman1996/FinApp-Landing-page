MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/finapp-marketing?retryWrites=true&w=majority
PORT=5000

# --- Enquiry email forwarding ---
# Address that receives website enquiries (defaults to finappacademy@gmail.com)
ENQUIRY_TO=finappacademy@gmail.com

# SMTP credentials for Nodemailer. For Gmail use a Google App Password.
# (Google Account → Security → 2-Step Verification → App passwords)
SMTP_SERVICE=gmail
SMTP_USER=finappacademy@gmail.com
SMTP_PASS=your-app-password-here
SMTP_FROM=FinApp Website <finappacademy@gmail.com>
